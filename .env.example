# OpenRouter API key (https://openrouter.ai). Used by:
#   c_generate_smartvote_dataset.py
#   l_generate_volksabstimmungen_dataset.py
# The OpenAI Python SDK reads OPENAI_API_KEY but the base URL is OpenRouter,
# so any OpenRouter key (sk-or-v1-...) works.
OPENAI_API_KEY="sk-or-v1-replace-with-your-openrouter-key"
